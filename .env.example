# =====================================================================
# Chimera — environment template
# Copy to `scraper.env` (gitignored) and fill in real values.
# Every config option here is also exposed in tool_manifest.json
# so cameleon can discover them at runtime.
# =====================================================================

# --- Paths (dev vs prod) ---------------------------------------------
# Dev (Codespace): /workspaces/chimera
# Prod (Ubuntu server): /opt/scraper-pack
SCRAPER_HOME=/workspaces/chimera

# --- Bridge ----------------------------------------------------------
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
BRIDGE_WORKERS=2

# Bearer token cameleon presents on every /run-tool call.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BRIDGE_AUTH_TOKEN=REPLACE_ME_WITH_A_LONG_RANDOM_TOKEN

# Comma-separated IP allowlist (enforced by nginx in prod; advisory in dev)
BRIDGE_ALLOWED_IPS=127.0.0.1

# Expose /docs, /redoc, /openapi.json
#   dev:  true  (browse Swagger UI freely)
#   prod: false (cameleon uses /capabilities; /docs would leak the API)
DOCS_ENABLED=true

# --- Redis / RQ ------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUES=high,normal,low
RQ_DEFAULT_TIMEOUT=600

# --- Logging ---------------------------------------------------------
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.jsonl
BRIDGE_LOG_PATH=logs/bridge.log
TOOLS_LOG_PATH=logs/tools.log

# --- Storage ---------------------------------------------------------
RESULTS_DIR=storage/results
SCREENSHOTS_DIR=storage/screenshots
COOKIES_DIR=storage/cookies
RISK_DB_PATH=storage/risk_db.sqlite

# --- Proxies (filled in Session 2) -----------------------------------
PROXY_POOL_PATH=network/proxy_pool/pool.json
DEFAULT_PROXY_TIER=datacenter

# --- Risk thresholds -------------------------------------------------
# Values mirror those in tool_manifest.json — keep in sync.
RISK_OK_MAX=0.2
RISK_SUSPECT_MAX=0.5
RISK_CHALLENGE_MAX=0.8

# --- Optional: external services (Session 3+) ------------------------
FIRECRAWL_URL=http://127.0.0.1:3002
# API key for self-hosted Firecrawl — must match TEST_API_KEY in docker-compose.firecrawl.yml.
# Change in prod; any non-empty string works when USE_DB_AUTHENTICATION=false.
FIRECRAWL_API_KEY=chimera-local
FIRECRAWL_PORT=3002
FLARESOLVERR_URL=http://127.0.0.1:8191/v1

# --- Bright Data Proxy Manager (Docker, optional) --------------------
BRIGHTDATA_PROXY_HOST=127.0.0.1
BRIGHTDATA_PROXY_PORT=24000
BRIGHTDATA_PM_DASHBOARD=http://127.0.0.1:22999

# --- Bright Data residential proxy credentials (scraper.env only) ----
# Never commit real credentials. Generate via Bright Data dashboard.
# BRIGHTDATA_USERNAME=brd-customer-XXXXX-zone-XXXXX
# BRIGHTDATA_PASSWORD=XXXXX
# BRIGHTDATA_HOST=brd.superproxy.io
# BRIGHTDATA_PORT=33335

# --- Account Factory (Step 3.6) -----------------------------------------
# Set to true to activate the APScheduler daily cron (runs at 09:00 UTC)
FACTORY_CRON_ENABLED=false
# Number of new profiles created per daily factory run
FACTORY_NEW_PROFILES_PER_DAY=2

# --- Groq API (Step 4.2) — WatchCount vision extraction ------------------
# Créer un compte sur https://console.groq.com — Free tier suffit pour dev.
# Utilisé uniquement en fallback reCAPTCHA : watchcount.com → screenshot → Groq vision → end_date
GROQ_API_KEY=

# --- eBay API credentials (Step 4.1) -------------------------------------
# Créer un compte développeur eBay : https://developer.ebay.com
# Production Application credentials → App ID (Client ID) + Cert ID (Client Secret)
# Supporte jusqu'à 3 clés pour la rotation (quota 4800/jour/clé)
EBAY_APP_ID_1=your_app_id_here
EBAY_CERT_ID_1=your_cert_id_here
EBAY_APP_ID_2=
EBAY_CERT_ID_2=
EBAY_APP_ID_3=
EBAY_CERT_ID_3=
EBAY_DEFAULT_MARKETPLACE=EBAY_FR
