{
  "site": "vinted.fr",
  "version": "1.1",
  "baseSelector": "[data-testid*='grid-item']",
  "fields": [
    {"name": "listing_id", "selector": "a[href*='/items/']", "type": "attribute", "attribute": "href", "transform": "extract_id_from_url"},
    {"name": "title", "selector": "a[href*='/items/']", "type": "attribute", "attribute": "title"},
    {"name": "price_raw", "selector": "[data-testid$='--price-text']", "type": "text"},
    {"name": "brand", "selector": "[data-testid$='--description-title']", "type": "text"},
    {"name": "size", "selector": "[data-testid$='--description-subtitle']", "type": "text"},
    {"name": "condition", "selector": "[data-testid$='--description-subtitle']", "type": "text"},
    {"name": "url", "selector": "a[href*='/items/']", "type": "attribute", "attribute": "href"},
    {"name": "photo_url", "selector": "img", "type": "attribute", "attribute": "src"}
  ]
}
