[Unit]
Description=Chimera Scraping Agent Cron
After=chimera-bridge.service

[Service]
WorkingDirectory=/workspaces/chimera
EnvironmentFile=/workspaces/chimera/scraper.env
ExecStart=/workspaces/chimera/.venv/bin/python3 scripts/scrape_cron.py
Restart=always
RestartSec=60
User=root

[Install]
WantedBy=multi-user.target
