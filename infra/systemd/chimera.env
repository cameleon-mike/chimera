# Chimera — EnvironmentFile template
# Copy to /etc/chimera/chimera.env on the prod host and fill secrets.
# Chmod 0640, owner root:chimera so the chimera user can read.

# --- Paths (prod layout) ---------------------------------------------
CHIMERA_HOME=/opt/chimera
CHIMERA_VENV=/opt/chimera/.venv
CHIMERA_USER=chimera

# Repo root used by bridge.config.REPO_ROOT — must match CHIMERA_HOME.
SCRAPER_HOME=/opt/chimera

# --- Bridge ----------------------------------------------------------
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8080
BRIDGE_WORKERS=2
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
BRIDGE_AUTH_TOKEN=REPLACE_ME_BEFORE_BOOT
BRIDGE_ALLOWED_IPS=127.0.0.1
DOCS_ENABLED=false

# --- Redis / RQ ------------------------------------------------------
REDIS_URL=redis://127.0.0.1:6379/0
RQ_QUEUES=high,normal,low
RQ_DEFAULT_TIMEOUT=600

# --- Logging ---------------------------------------------------------
LOG_LEVEL=INFO
AUDIT_LOG_PATH=/opt/chimera/logs/audit.jsonl
BRIDGE_LOG_PATH=/opt/chimera/logs/bridge.log
TOOLS_LOG_PATH=/opt/chimera/logs/tools.log

# --- Storage ---------------------------------------------------------
RESULTS_DIR=/opt/chimera/storage/results
SCREENSHOTS_DIR=/opt/chimera/storage/screenshots
COOKIES_DIR=/opt/chimera/storage/cookies
RISK_DB_PATH=/opt/chimera/storage/risk_db.sqlite

# --- Risk thresholds (mirror tool_manifest.json) ---------------------
RISK_OK_MAX=0.2
RISK_SUSPECT_MAX=0.5
RISK_CHALLENGE_MAX=0.8
